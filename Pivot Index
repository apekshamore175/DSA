import java.util.Scanner;

public class Practice {

    public static int pivotIndex(int[] arr) {
        int totalSum = 0;

        for (int num : arr) {
            totalSum += num;
        }

        int leftSum = 0;

        for (int i = 0; i < arr.length; i++) {
            int rightSum = totalSum - leftSum - arr[i];

            if (leftSum == rightSum) {
                return i;
            }
            leftSum += arr[i];
        }

        return -1;
    }

    public static void main(String[] args) {

        int[] arrr = { 1, 7, 3, 6, 5, 6 };

        int resultPivot = pivotIndex(arrr);

        System.out.println("Pivot Index: " + resultPivot);
    }
}
