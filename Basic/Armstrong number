class Solution {
    public boolean isArmstrong(int n) {
        int k = String.valueOf(n).length();
        int sum = 0;
        int num = n;

        while(num > 0){
            int LD = num % 10;
            sum += Math.pow(LD, k);
            num /= 10;
        }
        if(sum == n) return true;
        else return false;
    }
}
