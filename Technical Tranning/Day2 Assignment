import java.util.Scanner;

public class Code{

    public static boolean leapYear(int year){
        if(year % 4 == 0){
            return true;
        }

        return false;
    }

    public static void positiveNegative(int num){
        if(num > 0){
            System.out.println("Positive");
        }else if( num < 0){
            System.out.println("Negative");
        }else{
            System.out.println("Zero");
        }
    }

    public static void isCharacter(char ch){
        if((ch >= 64 && ch <= 90) || (ch >= 97 && ch <= 122)){
            System.out.println("Character is Alphabet");
        }else{
            System.out.println("Character is not alphabet");
        }
    }

    public static int sumOfNaturalNum(int num){
        int sum = 0;
        for(int i = 0 ;i <= num; i++){
            sum += i;
        }
        return sum;
    }

    public static int factorial(int num){
       
        if (num == 0 || num == 1) {
            return 1;
        }
        
        return num * factorial(num - 1);
    }

    public static void multiplicationTable(int n){
        for(int i = 1; i <=10;i++){
            System.out.println(n * i);
        }
    }

    public static void fibonacciSeries(int n){
        int n1 = 0;
        int n2 = 1;

        for(int i = 0; i < n ; i++){
            System.out.println(n1);

            int n3 = n1 + n2;
            n1 = n2;
            n2 = n3;
        }
    }

    public static int gcdOfNumber(int n1, int n2){
        if(n2 == 0){
            return n1;
        }
        return gcdOfNumber(n2, n1 % n2);
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        //que 1 leap year
        int year = sc.nextInt();
        System.out.println(leapYear(year));


        //que 2 num is positive or negative
        int num = sc.nextInt();
        positiveNegative(num);

        // que 3 find character is alphabet or not
        char ch = sc.next().charAt(0);
        isCharacter(ch);

        // que 4 sum of natural number
        int num = sc.nextInt();
        System.out.println(sumOfNaturalNum(num));

        //que 5 factorial of number
        int num = sc.nextInt();
        System.out.println(factorial(num));

         // que 6 multiplication table
        int num = sc.nextInt();
        multiplicationTable(num);

        //que 7 fibonacci series
        int num = sc.nextInt();
        fibonacciSeries(num);

        //que 8 gcd of two number

       System.out.println( gcdOfNumber(60, 36));

    }
}
